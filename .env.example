# Web Research Agent — environment variables
#
# Copy this file to `.env` and fill in your own values.
# Never commit your real `.env` to git.

# ============================================================
# Anthropic API key
# ============================================================
# Required for Claude Code's WebSearch / WebFetch tools when
# running outside a billed Claude Code session.

ANTHROPIC_API_KEY=""

# ============================================================
# Optional research integrations
# ============================================================
# Uncomment any of the following if you want to wire up
# additional research sources. None are required.

# SERPAPI_KEY=""
# BING_SEARCH_KEY=""
# PERPLEXITY_API_KEY=""
